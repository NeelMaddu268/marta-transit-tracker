// Template for local secrets. Copy this to Secrets.xcconfig (which is gitignored)
// and fill in your MARTA rail API key. Do NOT commit the real key.
//
//   cp Secrets.example.xcconfig Secrets.xcconfig
//
// The key value is alphanumeric; xcconfig treats "//" as a comment, so the
// value must not contain slashes (the MARTA key doesn't).

MARTA_RAIL_API_KEY = your_marta_rail_api_key_here
